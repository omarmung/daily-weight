WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
FEED_NAME=               # e.g. dustin — drives KV keys, blob filename, calendar name
FEED_START_DATE=         # e.g. 2024-01-01 — earliest date to pull from Withings
FEED_TIMEZONE=           # IANA name, e.g. America/Los_Angeles
FEED_UNITS=              # lbs or kg (defaults to kg if unset)

# Auto-provisioned by Vercel — do not set manually:
# UPSTASH_REDIS_REST_URL=    (add Upstash Redis via Vercel Marketplace)
# UPSTASH_REDIS_REST_TOKEN=  (add Upstash Redis via Vercel Marketplace)
# BLOB_READ_WRITE_TOKEN=     (add Vercel Blob storage)
# CRON_SECRET=
